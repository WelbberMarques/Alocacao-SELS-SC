# Copie este arquivo para .env e preencha os valores antes de executar

# Credenciais do usuario master (primeiro acesso)
MASTER_USERNAME=master
MASTER_SENHA_PADRAO=sua_senha_forte_aqui

# Chave da API ipqualityscore.com (verificacao de IP/VPN)
# Obtenha em: https://www.ipqualityscore.com
IPQS_API_KEY=sua_chave_aqui

# Supabase (auto-update e publicacao de versoes)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua_chave_publica_aqui
SUPABASE_SERVICE_KEY=sua_chave_service_aqui
